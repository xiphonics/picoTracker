{
  "version": 6,
  "configurePresets": [
    {
      "name": "pico-debug",
      "displayName": "Pico RP2040 Debug",
      "binaryDir": "${sourceDir}/../build",
      "cacheVariables": {
        "ADV": "false",
        "PICO_DEOPTIMIZED_DEBUG": "1",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "pico-release",
      "displayName": "Pico RP2040 Release",
      "binaryDir": "${sourceDir}/../build-opt",
      "cacheVariables": {
        "ADV": "false",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "pico-debug",
      "configurePreset": "pico-debug",
      "jobs": 16
    },
    {
      "name": "pico-release",
      "configurePreset": "pico-release",
      "jobs": 16
    }
  ]
}
